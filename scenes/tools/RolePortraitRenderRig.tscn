bbcode_enabled = true
text = "[color=#b9efff][b]真实美术工作流[/b][/color]\n\n1. 许可证 SHA-256 门禁\n2. 枚举真实 .blend / .fbx / .gltf / .glb / .obj\n3. 载入 ModelRoot，隐藏武器与下半身\n4. 在 ProceduralAttachmentRoot 添加简单几何附件\n5. CameraFront / CameraSide 共用三点布光\n6. 透明 SubViewport 以 1024×1536 渲染\n7. Lanczos 缩小到 512×768 RGBA\n8. 正式运行时只读取 PNG，不加载第三方 3D\n\n[color=#86a9b8]当前几何体仅为渲染台自检占位，不会被登记成 Quaternius 成品。[/color]"
fit_content = true
scroll_active = false

