[gd_scene load_steps=2 format=3]

[sub_resource type="GDScript" id="GDScript_final_settlement_v06_bench"]
script/source = "extends Node\n\nconst SERVICE_SCENE := preload(\"res://scenes/runtime/FinalSettlementPublicSnapshotService.tscn\")\nconst CASH_PRIVACY_COPY := \"现金为最终并列判定项，数值保密\"\nconst AUDIT_PUBLIC_CASH_TEXT := \"987654.32\"\nconst HIDDEN_CASH_TEXT := \"876543.21\"\nconst FORBIDDEN_PUBLIC_KEYS := [\n\t\"cash\",\n\t\"cash_cents\",\n\t\"cash_ledger_cents\",\n\t\"available\",\n\t\"available_cents\",\n\t\"escrow\",\n\t\"escrow_cents\",\n]\n\nvar _checks := 0\nvar _failures: Array[String] = []\n\n\nfunc _ready() -> void:\n\tcall_deferred(\"_run\")\n\n\nfunc _run() -> void:\n\tvar service: Node = SERVICE_SCENE.instantiate()\n\t_expect(service != null, \"production service scene instantiates\")\n\tif service == null:\n\t\t_report({})\n\t\treturn\n\tadd_child(service)\n\tservice.call(\"configure\", {})\n\n\tvar source: Dictionary = _source()\n\tvar authorized: Dictionary = service.call(\"compose\", source)\n\tvar authorized_board: Dictionary = authorized.get(\"board\", {}) if authorized.get(\"board\", {}) is Dictionary else {}\n\t_expect(_text(authorized_board.get(\"kpis\", [])).contains(AUDIT_PUBLIC_CASH_TEXT), \"authorized audit cash reaches KPI\")\n\t_expect(_text(authorized_board.get(\"money_sources\", [])).contains(AUDIT_PUBLIC_CASH_TEXT), \"authorized audit cash reaches money-source\")\n\t_expect(_text(authorized_board.get(\"ranks\", [])).contains(AUDIT_PUBLIC_CASH_TEXT), \"authorized audit cash reaches rank\")\n\t_expect(not _text(authorized).contains(HIDDEN_CASH_TEXT), \"non-audit seat exact cash stays hidden\")\n\t_expect(_text(authorized).contains(CASH_PRIVACY_COPY), \"non-audit seat receives privacy copy\")\n\t_expect(not str(authorized.get(\"summary_text\", \"\")).contains(AUDIT_PUBLIC_CASH_TEXT), \"summary does not duplicate a per-seat exact value\")\n\t_expect(not _contains_forbidden_cash_key(authorized), \"public snapshot contains no raw cash keys\")\n\n\tvar no_visibility: Dictionary = source.duplicate(true)\n\tno_visibility.erase(\"cash_visibility\")\n\tno_visibility[\"winner\"] = true\n\tno_visibility[\"game_over\"] = true\n\tvar no_visibility_snapshot: Dictionary = service.call(\"compose\", no_visibility)\n\t_expect(not _text(no_visibility_snapshot).contains(AUDIT_PUBLIC_CASH_TEXT), \"cash plus winner/game_over without visibility fails closed\")\n\t_expect(_text(no_visibility_snapshot).contains(CASH_PRIVACY_COPY), \"missing visibility renders privacy copy\")\n\n\tvar no_roster: Dictionary = source.duplicate(true)\n\tno_roster.erase(\"audit_revealed_player_indices\")\n\tvar no_roster_snapshot: Dictionary = service.call(\"compose\", no_roster)\n\t_expect(not _text(no_roster_snapshot).contains(AUDIT_PUBLIC_CASH_TEXT), \"public_audit without authoritative roster fails closed\")\n\t_expect(_text(no_roster_snapshot).contains(CASH_PRIVACY_COPY), \"missing roster renders privacy copy\")\n\n\tvar debug: Dictionary = service.call(\"debug_snapshot\")\n\t_expect(bool(debug.get(\"service_ready\", false)), \"service configured\")\n\t_expect(str(debug.get(\"cash_visibility_policy\", \"\")) == \"authoritative_public_audit_allowlist\", \"debug exposes authoritative allowlist policy\")\n\t_expect(bool(debug.get(\"cash_disclosure_fail_closed\", false)), \"debug exposes fail-closed policy\")\n\t_report(debug)\n\n\nfunc _source() -> Dictionary:\n\treturn {\n\t\t\"valid\": true,\n\t\t\"reason\": \"公开审计完成\",\n\t\t\"winner_names\": [\"审计公开席\"],\n\t\t\"cash_visibility\": \"public_audit\",\n\t\t\"audit_revealed_player_indices\": [0],\n\t\t\"required_top_n_gdp_per_minute\": 130,\n\t\t\"required_controlled_region_count\": 4,\n\t\t\"outcome_receipt\": {\n\t\t\t\"outcome_id\": \"victory.v06.mcp-bench.1\",\n\t\t\t\"reason_code\": \"public_audit_complete\",\n\t\t\t\"winner_player_indices\": [0],\n\t\t\t\"co_victory\": false,\n\t\t\t\"comparison_order\": [\"top_k_gdp_per_minute_cents\", \"controlled_region_count\", \"cash_ledger_cents\"],\n\t\t},\n\t\t\"money_source_entries\": [\n\t\t\t{\"rank\": 0, \"player_index\": 0, \"name\": \"审计公开席\", \"top_n_gdp_per_minute\": 145, \"controlled_region_count\": 4, \"winner\": true, \"cash_ledger_cents\": 98765432, \"gdp_per_minute\": 180},\n\t\t\t{\"rank\": 1, \"player_index\": 1, \"name\": \"非审计席\", \"top_n_gdp_per_minute\": 120, \"controlled_region_count\": 3, \"winner\": false, \"cash_ledger_cents\": 87654321, \"gdp_per_minute\": 150},\n\t\t],\n\t\t\"rank_entries\": [\n\t\t\t{\"player_index\": 0, \"name\": \"审计公开席\", \"top_n_gdp_per_minute\": 145, \"controlled_region_count\": 4, \"winner\": true, \"cash_ledger_cents\": 98765432, \"available_cents\": 87654320, \"escrow_cents\": 11111112, \"gdp_per_minute\": 180},\n\t\t\t{\"player_index\": 1, \"name\": \"非审计席\", \"top_n_gdp_per_minute\": 120, \"controlled_region_count\": 3, \"winner\": false, \"cash_ledger_cents\": 87654321, \"available_cents\": 76543210, \"escrow_cents\": 11111111, \"gdp_per_minute\": 150},\n\t\t],\n\t\t\"map_facts\": {\"active_city_count\": 3, \"destroyed_district_count\": 1, \"active_monster_count\": 1, \"monster_count\": 2},\n\t\t\"kpi_columns\": 4,\n\t\t\"money_columns\": 2,\n\t\t\"rank_columns\": 2,\n\t}\n\n\nfunc _contains_forbidden_cash_key(value: Variant) -> bool:\n\tif value is Dictionary:\n\t\tfor key_variant in value.keys():\n\t\t\tif FORBIDDEN_PUBLIC_KEYS.has(str(key_variant).to_lower()) or _contains_forbidden_cash_key(value[key_variant]):\n\t\t\t\treturn true\n\telif value is Array:\n\t\tfor item_variant in value:\n\t\t\tif _contains_forbidden_cash_key(item_variant):\n\t\t\t\treturn true\n\treturn false\n\n\nfunc _text(value: Variant) -> String:\n\treturn JSON.stringify(value)\n\n\nfunc _expect(condition: bool, message: String) -> void:\n\t_checks += 1\n\tif condition:\n\t\treturn\n\t_failures.append(message)\n\tpush_error(\"FINAL_SETTLEMENT_PUBLIC_SNAPSHOT_V06_BENCH: %s\" % message)\n\n\nfunc _report(debug: Dictionary) -> void:\n\tprint(\"FINAL_SETTLEMENT_PUBLIC_SNAPSHOT_V06_BENCH|status=%s|checks=%d|failures=%d|service_ready=%s|policy=%s|fail_closed=%s\" % [\n\t\t\"PASS\" if _failures.is_empty() else \"FAIL\",\n\t\t_checks,\n\t\t_failures.size(),\n\t\tstr(debug.get(\"service_ready\", false)),\n\t\tstr(debug.get(\"cash_visibility_policy\", \"\")),\n\t\tstr(debug.get(\"cash_disclosure_fail_closed\", false)),\n\t])\n"

[node name="FinalSettlementPublicSnapshotServiceV06Bench" type="Node"]
script = SubResource("GDScript_final_settlement_v06_bench")
