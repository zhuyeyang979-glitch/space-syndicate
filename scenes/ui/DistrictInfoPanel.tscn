[gd_scene load_steps=3 format=3]

[ext_resource type="Theme" path="res://themes/GameTheme.tres" id="1_theme"]
[ext_resource type="Script" path="res://scripts/ui/district_info_panel.gd" id="2_district_info"]

[node name="DistrictInfoPanel" type="PanelContainer"]
custom_minimum_size = Vector2(280, 132)
theme = ExtResource("1_theme")
script = ExtResource("2_district_info")

[node name="DistrictRows" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 6

[node name="DistrictTitle" type="Label" parent="DistrictRows"]
unique_name_in_owner = true
layout_mode = 2
text = "当前区域"
horizontal_alignment = 1

[node name="DistrictChipRow" type="HFlowContainer" parent="DistrictRows"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/h_separation = 6
theme_override_constants/v_separation = 3

[node name="DistrictDetail" type="Label" parent="DistrictRows"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
text = "选择地图区域后显示短详情。"
autowrap_mode = 3
