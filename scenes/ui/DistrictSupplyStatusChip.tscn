[gd_scene load_steps=3 format=3]

[ext_resource type="Theme" path="res://themes/GameTheme.tres" id="1_theme"]
[ext_resource type="Script" path="res://scripts/ui/district_supply_status_chip.gd" id="2_script"]

[node name="DistrictSupplyStatusChip" type="PanelContainer"]
custom_minimum_size = Vector2(34, 20)
theme = ExtResource("1_theme")
script = ExtResource("2_script")

[node name="ChipMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 6
theme_override_constants/margin_top = 2
theme_override_constants/margin_right = 6
theme_override_constants/margin_bottom = 2

[node name="DistrictSupplyStatusChipLabel" type="Label" parent="ChipMargin"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 9
text = "状态"
text_overrun_behavior = 3
