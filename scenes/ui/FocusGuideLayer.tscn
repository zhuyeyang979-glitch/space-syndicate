script = ExtResource("2_focus_guide_layer")

[node name="FocusGuidePanel" type="PanelContainer" parent="."]
unique_name_in_owner = true
layout_mode = 1
mouse_filter = 2

[node name="FocusGuideChip" type="PanelContainer" parent="."]
unique_name_in_owner = true
layout_mode = 1
mouse_filter = 2

[node name="FocusGuideMargin" type="MarginContainer" parent="FocusGuideChip"]
layout_mode = 2
