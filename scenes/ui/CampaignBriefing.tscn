[gd_scene load_steps=3 format=3]

[ext_resource type="Theme" path="res://themes/GameTheme.tres" id="1_theme"]
[ext_resource type="Script" path="res://scripts/ui/campaign_briefing.gd" id="2_script"]

[node name="CampaignBriefing" type="PanelContainer"]
custom_minimum_size = Vector2(760, 500)
theme = ExtResource("1_theme")
script = ExtResource("2_script")

[node name="CampaignBriefingMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 14
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 14

[node name="CampaignBriefingStack" type="VBoxContainer" parent="CampaignBriefingMargin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="CampaignBriefingHeader" type="VBoxContainer" parent="CampaignBriefingMargin/CampaignBriefingStack"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="CampaignBriefingTitle" type="Label" parent="CampaignBriefingMargin/CampaignBriefingStack/CampaignBriefingHeader"]
unique_name_in_owner = true
layout_mode = 2
text = "关卡说明"
theme_override_font_sizes/font_size = 24

[node name="CampaignBriefingSubtitle" type="Label" parent="CampaignBriefingMargin/CampaignBriefingStack/CampaignBriefingHeader"]
unique_name_in_owner = true
layout_mode = 2
text = "目标"

[node name="CampaignBriefingMeta" type="Label" parent="CampaignBriefingMargin/CampaignBriefingStack/CampaignBriefingHeader"]
unique_name_in_owner = true
layout_mode = 2
text = "约5分钟｜intro"
theme_override_font_sizes/font_size = 12

[node name="CampaignBriefingQuickCardRow" type="HFlowContainer" parent="CampaignBriefingMargin/CampaignBriefingStack"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/h_separation = 10
theme_override_constants/v_separation = 6

[node name="CampaignBriefingText" type="Label" parent="CampaignBriefingMargin/CampaignBriefingStack"]
unique_name_in_owner = true
layout_mode = 2
text = "开局说明"
autowrap_mode = 3

[node name="CampaignBriefingColumns" type="HBoxContainer" parent="CampaignBriefingMargin/CampaignBriefingStack"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 12

[node name="CampaignBriefingObjectives" type="VBoxContainer" parent="CampaignBriefingMargin/CampaignBriefingStack/CampaignBriefingColumns"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 5

[node name="CampaignBriefingAllowed" type="VBoxContainer" parent="CampaignBriefingMargin/CampaignBriefingStack/CampaignBriefingColumns"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 5

[node name="CampaignBriefingTeaches" type="VBoxContainer" parent="CampaignBriefingMargin/CampaignBriefingStack/CampaignBriefingColumns"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 5

[node name="CampaignBriefingReward" type="Label" parent="CampaignBriefingMargin/CampaignBriefingStack"]
unique_name_in_owner = true
layout_mode = 2
text = "奖励"
theme_override_font_sizes/font_size = 13

[node name="CampaignBriefingFooter" type="HBoxContainer" parent="CampaignBriefingMargin/CampaignBriefingStack"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="CampaignBriefingPrimaryButton" type="Button" parent="CampaignBriefingMargin/CampaignBriefingStack/CampaignBriefingFooter"]
unique_name_in_owner = true
custom_minimum_size = Vector2(170, 38)
layout_mode = 2
text = "开始本关"

[node name="CampaignBriefingSecondaryRow" type="HFlowContainer" parent="CampaignBriefingMargin/CampaignBriefingStack/CampaignBriefingFooter"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 6
