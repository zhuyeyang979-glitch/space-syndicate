[node name="BestiaryBrowserPreviousButton" type="Button" parent="BestiaryBrowserNavRow"]
unique_name_in_owner = true
custom_minimum_size = Vector2(112, 36)
layout_mode = 2
text = "缩略图上一页"

[node name="BestiaryBrowserPageLabel" type="Label" parent="BestiaryBrowserNavRow"]
