horizontal_alignment = 1
vertical_alignment = 1
text = "第1/1页"

[node name="BestiaryBrowserNextButton" type="Button" parent="BestiaryBrowserNavRow"]
unique_name_in_owner = true
custom_minimum_size = Vector2(112, 36)
layout_mode = 2
text = "缩略图下一页"

[node name="BestiaryBrowserOverviewHost" type="HFlowContainer" parent="."]
unique_name_in_owner = true
layout_mode = 2
