[node name="CampaignMenuPresetRow" type="HFlowContainer" parent="CampaignMenuMargin/CampaignMenuStack/CampaignMenuPresetBlock"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 6

[node name="CampaignMenuFooter" type="HBoxContainer" parent="CampaignMenuMargin/CampaignMenuStack"]
