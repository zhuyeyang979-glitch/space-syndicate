[gd_scene load_steps=3 format=3]

[ext_resource type="Theme" path="res://themes/GameTheme.tres" id="1_theme"]
[ext_resource type="Script" path="res://scripts/ui/scenario_replay_panel.gd" id="2_script"]

[node name="ScenarioReplayPanel" type="PanelContainer"]
custom_minimum_size = Vector2(420, 96)
theme = ExtResource("1_theme")
script = ExtResource("2_script")

[node name="ScenarioReplayStack" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 6

[node name="ScenarioReplayTitle" type="Label" parent="ScenarioReplayStack"]
unique_name_in_owner = true
layout_mode = 2
text = "剧本复盘｜关键快照"
theme_override_font_sizes/font_size = 16

[node name="ScenarioReplaySnapshotRow" type="HFlowContainer" parent="ScenarioReplayStack"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 6
theme_override_constants/v_separation = 5
