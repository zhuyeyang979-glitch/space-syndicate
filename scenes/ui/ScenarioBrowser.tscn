[gd_scene load_steps=3 format=3]

[ext_resource type="Theme" path="res://themes/GameTheme.tres" id="1_theme"]
[ext_resource type="Script" path="res://scripts/ui/scenario_browser.gd" id="2_script"]

[node name="ScenarioBrowser" type="PanelContainer"]
custom_minimum_size = Vector2(760, 520)
theme = ExtResource("1_theme")
script = ExtResource("2_script")

[node name="ScenarioBrowserMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 14
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 14
theme_override_constants/margin_bottom = 12

[node name="ScenarioBrowserStack" type="VBoxContainer" parent="ScenarioBrowserMargin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="ScenarioBrowserHeader" type="VBoxContainer" parent="ScenarioBrowserMargin/ScenarioBrowserStack"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="ScenarioBrowserTitle" type="Label" parent="ScenarioBrowserMargin/ScenarioBrowserStack/ScenarioBrowserHeader"]
unique_name_in_owner = true
layout_mode = 2
text = "试玩剧本"
theme_override_font_sizes/font_size = 24

[node name="ScenarioBrowserSubtitle" type="Label" parent="ScenarioBrowserMargin/ScenarioBrowserStack/ScenarioBrowserHeader"]
unique_name_in_owner = true
layout_mode = 2
text = "选择一个固定局面，练习核心系统。"
autowrap_mode = 3

[node name="ScenarioBrowserScroll" type="ScrollContainer" parent="ScenarioBrowserMargin/ScenarioBrowserStack"]
layout_mode = 2
size_flags_vertical = 3
horizontal_scroll_mode = 0

[node name="ScenarioBrowserCardGrid" type="GridContainer" parent="ScenarioBrowserMargin/ScenarioBrowserStack/ScenarioBrowserScroll"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
columns = 2
theme_override_constants/h_separation = 10
theme_override_constants/v_separation = 10

[node name="ScenarioBrowserFooter" type="HBoxContainer" parent="ScenarioBrowserMargin/ScenarioBrowserStack"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="ScenarioBrowserStartButton" type="Button" parent="ScenarioBrowserMargin/ScenarioBrowserStack/ScenarioBrowserFooter"]
unique_name_in_owner = true
custom_minimum_size = Vector2(180, 38)
layout_mode = 2
text = "开始剧本"

[node name="ScenarioBrowserSecondaryRow" type="HFlowContainer" parent="ScenarioBrowserMargin/ScenarioBrowserStack/ScenarioBrowserFooter"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 6
