[gd_scene load_steps=3 format=3]

[ext_resource type="Theme" path="res://themes/GameTheme.tres" id="1_theme"]
[ext_resource type="Script" path="res://scripts/ui/district_supply_preview_card.gd" id="2_script"]

[node name="DistrictSupplySelectedPreview" type="PanelContainer"]
layout_mode = 2
size_flags_horizontal = 3
mouse_filter = 1
