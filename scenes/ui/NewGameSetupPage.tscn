[gd_scene load_steps=5 format=3]

[ext_resource type="Theme" path="res://themes/GameTheme.tres" id="1_theme"]
[ext_resource type="Script" path="res://scripts/ui/new_game_setup_page.gd" id="2_script"]
[ext_resource type="PackedScene" path="res://scenes/ui/NewGameSetupLobby.tscn" id="3_lobby"]
[ext_resource type="PackedScene" path="res://scenes/ui/NewGameSetupOptionBoard.tscn" id="4_options"]

[node name="NewGameSetupPage" type="PanelContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme = ExtResource("1_theme")
script = ExtResource("2_script")

[node name="NewGameSetupPageMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 10

[node name="NewGameSetupPageStack" type="VBoxContainer" parent="NewGameSetupPageMargin"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="NewGameSetupSummaryChipRail" type="HFlowContainer" parent="NewGameSetupPageMargin/NewGameSetupPageStack"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 6
theme_override_constants/v_separation = 4

[node name="NewGameSetupLobbyPanel" parent="NewGameSetupPageMargin/NewGameSetupPageStack" instance=ExtResource("3_lobby")]
unique_name_in_owner = true
layout_mode = 2

[node name="NewGameSetupOptionBoard" parent="NewGameSetupPageMargin/NewGameSetupPageStack" instance=ExtResource("4_options")]
unique_name_in_owner = true
layout_mode = 2

[node name="NewGameSetupSeatTitle" type="Label" parent="NewGameSetupPageMargin/NewGameSetupPageStack"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(0.992, 0.906, 0.541, 1)
theme_override_font_sizes/font_size = 13
text = "座位卡｜公开角色 + 独立首召怪兽"

[node name="NewGameSetupSeatScroll" type="ScrollContainer" parent="NewGameSetupPageMargin/NewGameSetupPageStack"]
unique_name_in_owner = true
custom_minimum_size = Vector2(0, 360)
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
horizontal_scroll_mode = 0
vertical_scroll_mode = 1

[node name="NewGameSetupSeatGrid" type="GridContainer" parent="NewGameSetupPageMargin/NewGameSetupPageStack/NewGameSetupSeatScroll"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
columns = 1
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 8

[node name="NewGameSetupHintLabel" type="Label" parent="NewGameSetupPageMargin/NewGameSetupPageStack"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(0.58, 0.64, 0.72, 1)
theme_override_font_sizes/font_size = 12
text = "角色公开；首召匿名。先进桌召怪兽，再围绕怪兽附近买牌。"
horizontal_alignment = 1
autowrap_mode = 2

[node name="NewGameSetupActionRow" type="HBoxContainer" parent="NewGameSetupPageMargin/NewGameSetupPageStack"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="NewGameSetupStartButton" type="Button" parent="NewGameSetupPageMargin/NewGameSetupPageStack/NewGameSetupActionRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
text = "开始本局"

[node name="NewGameSetupBackButton" type="Button" parent="NewGameSetupPageMargin/NewGameSetupPageStack/NewGameSetupActionRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
text = "返回主菜单"

[node name="NewGameSetupReturnTableButton" type="Button" parent="NewGameSetupPageMargin/NewGameSetupPageStack/NewGameSetupActionRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
text = "返回牌桌"
tooltip_text = "不改变开局设置，回到当前进行中的牌桌。"
