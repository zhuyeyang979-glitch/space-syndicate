text_overrun_behavior = 3

[node name="SelectedDistrictChip" type="Label" parent="TopBarRow/FirstGlanceRail"]
unique_name_in_owner = true
layout_mode = 2
text = "选区｜未选择"
text_overrun_behavior = 3

[node name="PrimaryActionChip" type="Label" parent="TopBarRow/FirstGlanceRail"]
unique_name_in_owner = true
layout_mode = 2
text = "下一步｜查看地图"
text_overrun_behavior = 3

[node name="WeatherChip" type="Label" parent="TopBarRow/FirstGlanceRail"]
unique_name_in_owner = true
layout_mode = 2
