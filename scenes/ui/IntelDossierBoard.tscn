[gd_scene load_steps=3 format=3]

[ext_resource type="Theme" path="res://themes/GameTheme.tres" id="1_theme"]
[ext_resource type="Script" path="res://scripts/ui/intel_dossier_board.gd" id="2_script"]

[node name="IntelDossierBoardPanel" type="PanelContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme = ExtResource("1_theme")
script = ExtResource("2_script")

[node name="IntelDossierBoardMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 14
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 14
theme_override_constants/margin_bottom = 12

[node name="IntelDossierBoardStack" type="VBoxContainer" parent="IntelDossierBoardMargin"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="IntelDossierBoardHeader" type="HBoxContainer" parent="IntelDossierBoardMargin/IntelDossierBoardStack"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="IntelDossierBoardTitle" type="Label" parent="IntelDossierBoardMargin/IntelDossierBoardStack/IntelDossierBoardHeader"]
unique_name_in_owner = true
layout_mode = 2
text = "情报侦探板"

[node name="IntelDossierBoardHeaderSpacer" type="Control" parent="IntelDossierBoardMargin/IntelDossierBoardStack/IntelDossierBoardHeader"]
layout_mode = 2
size_flags_horizontal = 3

[node name="IntelDossierBoardChipRail" type="HFlowContainer" parent="IntelDossierBoardMargin/IntelDossierBoardStack/IntelDossierBoardHeader"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 5
theme_override_constants/v_separation = 3

[node name="IntelDossierKpiGrid" type="GridContainer" parent="IntelDossierBoardMargin/IntelDossierBoardStack"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
columns = 4
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 8

[node name="IntelDossierActionRow" type="HFlowContainer" parent="IntelDossierBoardMargin/IntelDossierBoardStack"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 6
theme_override_constants/v_separation = 4

[node name="IntelDossierClueGrid" type="GridContainer" parent="IntelDossierBoardMargin/IntelDossierBoardStack"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
columns = 3
theme_override_constants/h_separation = 10
theme_override_constants/v_separation = 10

[node name="IntelDossierControlTitle" type="Label" parent="IntelDossierBoardMargin/IntelDossierBoardStack"]
unique_name_in_owner = true
layout_mode = 2
text = "私人推理控制｜只修改当前玩家自己的标注"

[node name="IntelDossierControlGrid" type="GridContainer" parent="IntelDossierBoardMargin/IntelDossierBoardStack"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
columns = 1
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 8

[node name="IntelDossierLinkTitle" type="Label" parent="IntelDossierBoardMargin/IntelDossierBoardStack"]
