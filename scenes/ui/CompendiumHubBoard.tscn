[gd_scene load_steps=3 format=3]

[ext_resource type="Theme" path="res://themes/GameTheme.tres" id="1_theme"]
[ext_resource type="Script" path="res://scripts/ui/compendium_hub_board.gd" id="2_script"]

[node name="CompendiumHubBoardPanel" type="PanelContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme = ExtResource("1_theme")
script = ExtResource("2_script")

[node name="CompendiumHubMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 14
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 14
theme_override_constants/margin_bottom = 12

[node name="CompendiumHubStack" type="VBoxContainer" parent="CompendiumHubMargin"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="CompendiumHubHeader" type="HBoxContainer" parent="CompendiumHubMargin/CompendiumHubStack"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="CompendiumHubTitle" type="Label" parent="CompendiumHubMargin/CompendiumHubStack/CompendiumHubHeader"]
unique_name_in_owner = true
layout_mode = 2
text = "资料大厅"

[node name="CompendiumHubHeaderSpacer" type="Control" parent="CompendiumHubMargin/CompendiumHubStack/CompendiumHubHeader"]
layout_mode = 2
size_flags_horizontal = 3

[node name="CompendiumHubChipRail" type="HFlowContainer" parent="CompendiumHubMargin/CompendiumHubStack/CompendiumHubHeader"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 5
theme_override_constants/v_separation = 3

[node name="CompendiumHubKpiGrid" type="GridContainer" parent="CompendiumHubMargin/CompendiumHubStack"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
columns = 3
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 8

[node name="CompendiumHubActionTitle" type="Label" parent="CompendiumHubMargin/CompendiumHubStack"]
unique_name_in_owner = true
layout_mode = 2
text = "图鉴分支｜选择一个资料板"

[node name="CompendiumHubActionGrid" type="GridContainer" parent="CompendiumHubMargin/CompendiumHubStack"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
columns = 3
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 8

[node name="CompendiumHubFooterHint" type="Label" parent="CompendiumHubMargin/CompendiumHubStack"]
unique_name_in_owner = true
layout_mode = 2
text = "图鉴只承载长资料；主桌继续只保留当前行动和短解释。"
autowrap_mode = 2
