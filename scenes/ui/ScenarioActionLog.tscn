[gd_scene load_steps=3 format=3]

[ext_resource type="Theme" path="res://themes/GameTheme.tres" id="1_theme"]
[ext_resource type="Script" path="res://scripts/ui/scenario_action_log.gd" id="2_script"]

[node name="ScenarioActionLog" type="PanelContainer"]
custom_minimum_size = Vector2(360, 240)
theme = ExtResource("1_theme")
script = ExtResource("2_script")

[node name="ScenarioActionLogStack" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 6

[node name="ScenarioActionLogTitle" type="Label" parent="ScenarioActionLogStack"]
unique_name_in_owner = true
layout_mode = 2
text = "剧本行动日志"
theme_override_font_sizes/font_size = 17

[node name="ScenarioActionLogScroll" type="ScrollContainer" parent="ScenarioActionLogStack"]
layout_mode = 2
size_flags_vertical = 3
horizontal_scroll_mode = 0

[node name="ScenarioActionLogEntries" type="VBoxContainer" parent="ScenarioActionLogStack/ScenarioActionLogScroll"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 5
