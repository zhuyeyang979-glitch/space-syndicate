[gd_scene load_steps=3 format=3]

[ext_resource type="Theme" path="res://themes/GameTheme.tres" id="1_theme"]
[ext_resource type="Script" path="res://scripts/ui/contract_response_decision_panel.gd" id="2_script"]

[node name="ContractResponseDecisionPanel" type="PanelContainer"]
visible = false
custom_minimum_size = Vector2(360, 214)
theme = ExtResource("1_theme")
script = ExtResource("2_script")

[node name="ContractResponseMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 9

[node name="ContractResponseRows" type="VBoxContainer" parent="ContractResponseMargin"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="ContractResponseHeader" type="HBoxContainer" parent="ContractResponseMargin/ContractResponseRows"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="ContractResponseTitleLabel" type="Label" parent="ContractResponseMargin/ContractResponseRows/ContractResponseHeader"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
text = "匿名合约签署窗口"
text_overrun_behavior = 3

[node name="ContractResponseTimerLabel" type="Label" parent="ContractResponseMargin/ContractResponseRows/ContractResponseHeader"]
unique_name_in_owner = true
layout_mode = 2
text = "30s"
horizontal_alignment = 2
text_overrun_behavior = 3

[node name="ContractResponseRouteLabel" type="Label" parent="ContractResponseMargin/ContractResponseRows"]
unique_name_in_owner = true
layout_mode = 2
text = "供应区 → 需求区"
text_overrun_behavior = 3

[node name="ContractResponseProductLabel" type="Label" parent="ContractResponseMargin/ContractResponseRows"]
unique_name_in_owner = true
layout_mode = 2
text = "商品｜未指定"
text_overrun_behavior = 3

[node name="ContractResponseAcceptLabel" type="Label" parent="ContractResponseMargin/ContractResponseRows"]
unique_name_in_owner = true
layout_mode = 2
text = "签约｜按卡面结算"
autowrap_mode = 3

[node name="ContractResponseRejectLabel" type="Label" parent="ContractResponseMargin/ContractResponseRows"]
unique_name_in_owner = true
layout_mode = 2
text = "拒绝｜按卡面结算"
autowrap_mode = 3

[node name="ContractResponsePrivacyLabel" type="Label" parent="ContractResponseMargin/ContractResponseRows"]
unique_name_in_owner = true
layout_mode = 2
text = "只有目标商品控制者可操作。"
autowrap_mode = 3

[node name="ContractResponseChipRow" type="HFlowContainer" parent="ContractResponseMargin/ContractResponseRows"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/h_separation = 6
theme_override_constants/v_separation = 4

[node name="ContractResponseActionGrid" type="GridContainer" parent="ContractResponseMargin/ContractResponseRows"]
unique_name_in_owner = true
layout_mode = 2
columns = 2
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 6
