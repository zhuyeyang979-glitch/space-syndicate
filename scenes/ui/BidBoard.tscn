[gd_scene load_steps=3 format=3]

[ext_resource type="Theme" path="res://themes/GameTheme.tres" id="1_theme"]
[ext_resource type="Script" path="res://scripts/ui/bid_board.gd" id="2_bid_board"]

[node name="BidBoard" type="PanelContainer"]
custom_minimum_size = Vector2(260, 56)
theme = ExtResource("1_theme")
script = ExtResource("2_bid_board")

[node name="BidBoardRows" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 2

[node name="BidBoardHeader" type="HBoxContainer" parent="BidBoardRows"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="BidBoardTitle" type="Label" parent="BidBoardRows/BidBoardHeader"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
text = "公开竞价"
text_overrun_behavior = 3

[node name="BidBoardPhase" type="Label" parent="BidBoardRows/BidBoardHeader"]
unique_name_in_owner = true
custom_minimum_size = Vector2(70, 0)
layout_mode = 2
text = "预设"
horizontal_alignment = 2
text_overrun_behavior = 3

[node name="BidBoardChipRow" type="HFlowContainer" parent="BidBoardRows"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/h_separation = 4
theme_override_constants/v_separation = 2

[node name="BidBoardTrackLinkRow" type="HFlowContainer" parent="BidBoardRows"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/h_separation = 4
theme_override_constants/v_separation = 2

[node name="BidBoardActionRow" type="HFlowContainer" parent="BidBoardRows"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/h_separation = 4
theme_override_constants/v_separation = 2

[node name="BidBoardStatus" type="Label" parent="BidBoardRows"]
unique_name_in_owner = true
layout_mode = 2
text = "下一张牌可预设报价。"
text_overrun_behavior = 3
