      ],
      "required_authority_predicates": [
        "victory_control.cash_visibility == public_audit",
        "player_index is an integer member of victory_control.audit_revealed_player_indices",
        "audit_entry.cash_visibility == public_audit",
        "audit_entry.cash_ledger_cents is an integer from the authoritative Victory public projection"
      ],
      "impact": "markerless, stale or malformed audit rows can disclose or fabricate exact rival cash and forward unallowlisted economic-asset counts",
      "test_gap": {
        "file": "tests/standings_public_snapshot_service_test.gd",
