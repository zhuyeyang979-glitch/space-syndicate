func categories() -> Array[String]:
	var result: Array[String] = []
	for category in CATEGORY_ORDER:
		result.append(str(category))
	return result


func records() -> Array:
	return _duplicate_records(RECORDS)


func records_for_category(category: String) -> Array:
	var result: Array = []
	for record in RECORDS:
		if str(record.get("category", "")) == category:
			result.append((record as Dictionary).duplicate(true))
	return result


func record_for_path(scene_path: String) -> Dictionary:
	for record in RECORDS:
		if str(record.get("scene_path", "")) == scene_path:
			return (record as Dictionary).duplicate(true)
	return {}


func scene_paths() -> Array[String]:
	var result: Array[String] = []
	for record in RECORDS:
		result.append(str(record.get("scene_path", "")))
	return result


