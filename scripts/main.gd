		{"name": "ňÉîňť║ŠÇ¬ňůŻ", "value": int(parts["monster"])},
	]
	var picked := []
	while picked.size() < 3 and not candidates.is_empty():
		var best_pos := -1
		var best_value := 0
		for i in range(candidates.size()):
			var value := int(candidates[i]["value"])
