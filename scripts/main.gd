func _recent_table_event_clean_text(line: String) -> String:
	var text := line.strip_edges()
	if text.begins_with("["):
		var close_index := text.find("] ")
		if close_index >= 0:
			text = text.substr(close_index + 2).strip_edges()
	text = text.replace("\n", " ").replace("\t", " ")
	return text


func _recent_table_event_accent(text: String) -> Color:
	if text.contains("жА™еЕљ") or text.contains("дЉ§еЃ≥") or text.contains("иµМе±А") or text.contains("жСІжѓБ"):
		return Color("#fb7185")
	if text.contains("еЯОеЄВ") or text.contains("еїЇеЯО") or text.contains("еЯОеЄВеМЦ") or text.contains("GDP"):
		return Color("#4ade80")
	if text.contains("еН°зЙМ") or text.contains("еМњеРН") or text.contains("еЗЇзЙМ") or text.contains("зЙМ"):
		return Color("#c084fc")
	if text.contains("зО∞йЗС") or text.contains("жФґеЕ•") or text.contains("¬•"):
		return Color("#facc15")
	if text.contains("е§©ж∞Ф") or text.contains("йҐДжК•") or text.contains("еРИзЇ¶"):
		return Color("#38bdf8")
	return Color("#bfdbfe")


