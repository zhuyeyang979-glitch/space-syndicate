						violations.append("%sšÜä%s %.1fńŞÄňů╝ň«╣ÚĽťňâĆ%s %.1fńŞŹńŞÇŔç┤" % [skill_name, seconds_key, seconds_value, turns_key, expected_seconds])
	return {
		"violations": violations,
		"seconds_card_count": seconds_cards.size(),
		"compatibility_mirror_count": compatibility_mirrors.size(),
