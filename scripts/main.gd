func _monster_action_motion_family(action: Dictionary) -> String:
	var action_name := String(action.get("name", ""))
	var range_meters := float(action.get("range", 0.0))
	var move_override_mps := float(action.get("move_override", -1.0))
	if action.has("throw_radius"):
		return "throw_grapple"
	if action.has("miasma_count"):
		return "miasma_zone"
	if action.has("repair") or action.has("repair_radius") or action.has("repair_path"):
		return "repair_beam"
	if action_name.contains("еТЖеУЃ"):
		return "roar_wave"
	if action_name.contains("жљЬ"):
		return "burrow_dash"
	if action_name.contains("жЙУжїЪ") or action_name.contains("жїЪ"):
		return "roll_crush"
	if action_name.contains("зВЄеЉє") or action_name.contains("зИЖи£В") or action_name.contains("зИЖеЉє"):
		return "blast_projectile"
	if action_name.contains("еЕЙзЇњ") or action_name.contains("е∞ДзЇњ") or action_name.contains("зБЂиК±") or action_name.contains("ињЮйЧ™") or range_meters >= 420.0:
		return "beam_line"
	if move_override_mps > 0.0 and int(action.get("damage", 0)) > 0:
		return "dash_melee"
	if float(action.get("knockback", 0.0)) > 0.0:
		return "impact_melee"
	if int(action.get("damage", 0)) > 0:
		return "close_melee"
	return "utility_pose"


func _monster_action_effect_layer(action: Dictionary) -> String:
	var action_name := String(action.get("name", ""))
	if action.has("miasma_count") or action_name.contains("зШі"):
		return "miasma_cloud"
	if action.has("repair") or action.has("repair_radius") or action.has("repair_path"):
		return "repair_green"
	if action.has("paralyze") or action_name.contains("зФµ") or action_name.contains("йЧ™"):
		return "electric_arc"
	if action.has("cripple") or action_name.contains("еИГ") or action_name.contains("жЦ©"):
		return "blade_arc"
	if action.has("stun") or action.has("knockback") or action.has("throw_radius"):
		return "impact_burst"
	if action_name.contains("зБЂ") or action_name.contains("зД∞") or action_name.contains("зИЖ"):
		return "flame_burst"
	if action_name.contains("ж≥•") or action_name.contains("еЬ∞"):
		return "ground_crack"
	if action_name.contains("еТЖеУЃ") or action_name.contains("жљЃ") or action_name.contains("ж≥Ґ"):
		return "shock_wave"
	return "body_motion"


func _monster_action_pose_key(action_name: String) -> String:
	var pose_seed := _art_identity_text_seed(action_name)
	return "%s_%03d" % [_monster_action_pose_family(action_name), pose_seed % 997]


func _monster_action_pose_family(action_name: String) -> String:
	if action_name.contains("зњЉ") or action_name.contains("дњѓеЖ≤"):
		return "air_sweep"
	if action_name.contains("еЖ≤йФЛ") or action_name.contains("иВ©жТЮ") or action_name.contains("зЛВе•Ф"):
		return "charge"
	if action_name.contains("еЕЙзЇњ") or action_name.contains("е∞ДзЇњ") or action_name.contains("зБЂиК±") or action_name.contains("ињЮйЧ™"):
		return "beam"
	if action_name.contains("зВЄеЉє") or action_name.contains("зИЖ"):
		return "bomb"
	if action_name.contains("дњЃе§Н") or action_name.contains("иЧ§") or action_name.contains("зїњжі≤"):
		return "support"
	if action_name.contains("зШі") or action_name.contains("иЕРиЪА"):
		return "miasma"
	if action_name.contains("жЦ©") or action_name.contains("еИГ") or action_name.contains("жЙЛеИА"):
		return "blade"
	if action_name.contains("ж≥•") or action_name.contains("жљЬ") or action_name.contains("жїЪ"):
		return "earth"
	if action_name.contains("еТЖеУЃ") or action_name.contains("йЧ™еЕЙ"):
		return "wave"
	if action_name.contains("жЛ≥") or action_name.contains("иЄҐ") or action_name.contains("е∞Њ") or action_name.contains("жОМ"):
		return "melee"
	return "pose"


func _monster_action_anticipation_seconds(motion_family: String, range_meters: float, move_override_mps: float) -> float:
	if motion_family == "beam_line" or motion_family == "blast_projectile":
		return 0.32
	if motion_family == "dash_melee" or move_override_mps > 0.0:
		return 0.22
	if motion_family == "throw_grapple":
		return 0.28
	if range_meters <= 140.0:
		return 0.18
	return 0.24


func _monster_action_active_seconds(motion_family: String, range_meters: float, knockback_meters: float, throw_meters: float) -> float:
	if motion_family == "beam_line":
		return clampf(0.28 + range_meters / 2000.0, 0.32, 0.62)
	if motion_family == "throw_grapple":
		return 0.46
	if knockback_meters > 0.0 or throw_meters > 0.0:
		return 0.42
	return 0.30


func _monster_action_recovery_seconds(motion_family: String, damage: int) -> float:
	if motion_family == "blast_projectile" or damage >= 5:
		return 0.58
	if motion_family == "beam_line":
		return 0.42
	return 0.30


func _monster_action_scale_contract(action: Dictionary) -> String:
	var range_meters := float(action.get("range", 0.0))
	var move_override_mps := float(action.get("move_override", -1.0))
	var knockback_meters := float(action.get("knockback", 0.0))
	var throw_meters := float(action.get("throw_radius", 0.0))
	return "range:%smпљЬmove:%sm/sпљЬknock:%smпљЬthrow:%smпљЬlinear-meter-stage" % [
		_meters_number_text(range_meters),
