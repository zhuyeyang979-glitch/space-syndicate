	return "ŠâůŠŐąšÄ░ÚçĹ%s = šîťň»╣%d├Ś┬ą%d - šîťÚöÖ%d├Ś┬ą%d´ŻťňĚ▓Šáç%d/%d" % [
		_signed_int_text(int(stats.get("cash", 0))),
		int(stats.get("correct", 0)),
		int(stats.get("correct_reward", INTEL_CORRECT_GUESS_CASH)),
