			violations.append("%sšÜäšÄęň«ÂŠľçŠťČń╗ŹňÉźňĹĘŠťčňĆúňżä" % skill_name)
		for pair_variant in duration_pairs:
			var pair := pair_variant as Dictionary
			var turns_key := String(pair.get("turns", ""))
			var seconds_key := String(pair.get("seconds", ""))
			var has_turns := skill.has(turns_key) and int(skill.get(turns_key, 0)) > 0
			var has_seconds := skill.has(seconds_key) and float(skill.get(seconds_key, 0.0)) > 0.0
			if has_turns and not has_seconds:
				violations.append("%sńŻ┐šöĘ%sńŻćš╝║ň░Ĺ%s" % [skill_name, turns_key, seconds_key])
			if has_seconds:
				_append_unique_string(seconds_cards, skill_name)
