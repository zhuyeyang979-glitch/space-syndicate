func _temporary_economy_seconds_audit() -> Dictionary:
	var duration_pairs := [
		{"turns": "contract_turns", "seconds": "contract_seconds"},
		{"turns": "route_flow_turns", "seconds": "route_flow_seconds"},
		{"turns": "market_contract_turns", "seconds": "market_contract_seconds"},
