	match phase:
		"opening":
			return "ň╝Çň▒Ç´╝Üń╝śňůłÚŽľňĆČŃÇüň╗║ňčÄňĺîń╣░ňč║šíÇš╗ĆŠÁÄšëîŃÇé"
		"endgame":
