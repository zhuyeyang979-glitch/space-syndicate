	if charges <= 0:
		_log("%sж≤°жЬЙеЙ©дљЩеМЇеЯЯиЇЂдїљдЊ¶жµЛжђ°жХ∞гАВ" % String(role.get("name", "ељУеЙНиІТиЙ≤")))
		return false
	role["intel_city_reveal_charges"] = charges - 1
	players[player_index]["role_card"] = role
	var marked := _mark_city_guess_for_player(player_index, city_index, city_owner, CITY_GUESS_CONFIDENCE_HIGH, CITY_GUESS_REASON_ROLE)
	if marked:
		_record_player_economic_event(player_index, "жГЕжК•", String(role.get("name", source)), 0, "жЯ•жШО%sзЬЯеЃЮдЄЪдЄїдЄЇзО©еЃґ%dпЉЫз≠Фж°ИеП™ињЫеЕ•зІБдЇЇж†Зж≥®гАВ" % [
			String(districts[city_index].get("name", "еМЇеЯЯ")),
			city_owner + 1,
		])
		_log("%sжґИиАЧ%sпЉЪжЯ•жШО%sзЪДзЬЯеЃЮдЄЪдЄїеєґеЖЩеЕ•зІБдЇЇеЬ∞еЫЊпЉЫеЙ©дљЩ%dжђ°гАВ" % [
			String(players[player_index].get("name", "зО©еЃґ")),
			String(role.get("name", source)),
			String(districts[city_index].get("name", "еМЇеЯЯ")),
			charges - 1,
		])
	return marked


