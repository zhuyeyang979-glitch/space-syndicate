		var city_products := _city_product_names(city)
		var city_demands := _city_demand_names(city)
		var clues := city.get("public_clues", []) as Array
		if clues.is_empty():
			var last_clue := String(city.get("last_public_clue", ""))
			if last_clue != "":
				clues = [last_clue]
		for i in range(clues.size() - 1, -1, -1):
