	if city_owner < 0 or city_owner >= players.size() or city_owner == player_index:
		_log("%sдЄНжШѓйЩМзФЯеЯОеЄВпЉЫиЇЂдїљдЊ¶жµЛдЄНдЉЪжґИиАЧгАВ" % String(districts[city_index].get("name", "еМЇеЯЯ")))
