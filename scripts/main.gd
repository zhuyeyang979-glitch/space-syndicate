func _card_choice_location_summary(skill_name: String) -> String:
	var names := []
	var total := 0
	for i in range(districts.size()):
		if not _district_has_card(i, skill_name):
			continue
		total += 1
		if names.size() < 3:
			names.append(String(districts[i]["name"]))
	if total <= 0:
		return "жЪВжЬ™жКХжФЊеИ∞еМЇеЯЯ"
	var suffix := ""
	if total > names.size():
		suffix = " з≠Й%dдЄ™еМЇеЯЯеПѓеПЦ" % total
	else:
		suffix = "еПѓеПЦ"
	return "еЬ®%s%s" % [" / ".join(names), suffix]


func _is_upgrade_card(skill_name: String) -> bool:
