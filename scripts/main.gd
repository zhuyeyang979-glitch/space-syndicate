	players[player_index] = player
	_record_player_economic_event(player_index, "ŔžĺŔë▓ŠöÂšŤŐ", "ÚóŁňĄľŠő┐šëî", 0, "%sňî║ňččŔ┤şšëî´ŻťňůŹŔ┤╣ŔÄĚňżŚ%s" % [product_name, _card_display_name(bonus_card)])
	_log("ńŞÇŠČíňî┐ňÉŹňî║ňččŔ┤şšëîŔžŽňĆĹ%sšÜäÚóŁňĄľŔíąš╗ÖŠŁíń╗Â´╝ŤňůĚńŻôń╣░ň«ÂŃÇüňŹíšëîňĺîŠëőšëîšŐÂŠÇüńŞŹňůČň╝ÇŃÇé" % [
		String(role.get("name", "ŔžĺŔë▓ňŹí")),
	])
