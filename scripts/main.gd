					continue
				if float(preferences.get(secondary_id, 1.0)) > 1.001:
					secondary_routes.append(_development_route_label(secondary_id))
		profile_entries.append({
			"profile": String(profile.get("name", "AI")),
			"style": String(profile.get("style", "")),
