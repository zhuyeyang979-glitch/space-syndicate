		points,
		_card_rank_budget_role_text(card_name),
		drivers,
		gates,
	]


func _region_card_choice_summary(district_index: int, limit: int = 5) -> String:
	if district_index < 0 or district_index >= districts.size():
		return "无"
	var choices: Array = districts[district_index].get("card_choices", [])
	if choices.is_empty():
		return "无"
	var pieces := []
	for i in range(min(limit, choices.size())):
		var skill_name := String(choices[i])
		pieces.append("%s ¥%d（%s）" % [
			skill_name,
			_card_price(skill_name, district_index),
			_district_card_source(district_index, skill_name),
		])
	if choices.size() > limit:
		pieces.append("+%d" % (choices.size() - limit))
	return "、".join(pieces)


func _region_codex_accent(index: int) -> Color:
	if index < 0 or index >= districts.size():
		return Color("#38bdf8")
	var district: Dictionary = districts[index]
	if bool(district.get("destroyed", false)):
		return Color("#fb7185")
	match String(district.get("terrain", "land")):
		"ocean":
			return Color("#38bdf8")
		"volcanic":
			return Color("#fb923c")
		"ice":
			return Color("#a5f3fc")
		"desert":
			return Color("#facc15")
	return Color("#4ade80")


func _region_codex_terrain_icon(index: int) -> String:
	if index < 0 or index >= districts.size():
		return "⬡"
	var district: Dictionary = districts[index]
	if bool(district.get("destroyed", false)):
		return "✕"
	if _city_is_active(_district_city(index)):
		return "▣"
	if String(district.get("terrain", "land")) == "ocean":
		return "≈"
	return "⬡"


func _region_codex_city_status_text(index: int) -> String:
