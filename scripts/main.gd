	var title := _plain_label(title_text, 13, style.get("title", Color("#e5e7eb")) as Color)
	title.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	header.add_child(title)
	var badge := String(spec.get("badge", ""))
