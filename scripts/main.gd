		String(profile.get("label", "ŠĚ▒ň║ŽI")),
		float(profile.get("width", MAP_WIDTH_METERS)),
		float(profile.get("height", MAP_HEIGHT_METERS)),
		int(profile.get("region_min", MAP_REGION_COUNT_MIN)),
