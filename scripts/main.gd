	var source_text := "пЉЫзФ±%sжФєеЖЩ" % _card_display_name(source_card) if source_card != "" else ""
	_log("еМњеРНеПНеИґзФЯжХИпЉЪ%sеПЦжґИдЇЖ%sзЪДзїУзЃЧ%sгАВеПНеИґиАЕдїНдЄНеЕђеЉАгАВ" % [counter_label, target_label, source_text])
	_add_action_callout(
		"еМњеРНеПНеИґ",
		counter_label,
		"%sиҐЂзЫЄдљНжКШеП†пЉМеОЯзЙМдЄНдЇІзФЯжХИжЮЬпЉЫеПНеИґиАЕдЄНеЕђеЉАгАВ" % target_label,
		Color("#a78bfa"),
		_district_center(int(target_entry.get("selected_district", selected_district)))
	)
