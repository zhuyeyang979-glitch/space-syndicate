func _selected_district_status_text(player_index: int) -> String:
	if selected_district < 0 or selected_district >= districts.size():
		return "жЬ™йАЙжЛ©еМЇеЯЯ"
	var district: Dictionary = districts[selected_district]
	var terrain := String(district.get("terrain_label", "жµЈжіЛ" if String(district.get("terrain", "land")) == "ocean" else "йЩЖеЬ∞"))
	if bool(district.get("destroyed", false)):
		return "%sпљЬ%sпљЬеМЇеЯЯеЈ≤жѓБ" % [String(district.get("name", "еМЇеЯЯ")), terrain]
	var city := _district_city(selected_district)
	if _city_is_active(city):
		var gdp := _city_gdp_per_minute(selected_district, int(city.get("competition_matches", 0)))
		var owner_text := _selected_city_owner_view_text()
		if player_index < 0 or player_index >= players.size():
			owner_text = "ељТе±ЮеЊЕзМЬ"
		return "%sпљЬ%sпљЬ%sпљЬGDP %d/min" % [
			String(district.get("name", "еМЇеЯЯ")),
			terrain,
			owner_text,
			gdp,
		]
	if not city.is_empty():
		return "%sпљЬ%sпљЬеЯОеЄВеЇЯеҐЯ" % [String(district.get("name", "еМЇеЯЯ")), terrain]
	var settle_text := "еПѓеЯОеЄВеМЦ" if String(district.get("terrain", "land")) != "ocean" else "ињРиЊУжµЈеЯЯ"
	return "%sпљЬ%sпљЬ%s" % [String(district.get("name", "еМЇеЯЯ")), terrain, settle_text]


