			"value": count,
			"text": "%d席" % count,
			"pressed": count == configured_player_count,
			"tooltip": "%d名玩家席位；至少1名真人，其余可由AI补足。" % count,
		})

	var ai_entries := []
	var max_ai := mini(MAX_AI_PLAYER_COUNT, configured_player_count - 1)
	for count in range(MIN_AI_PLAYER_COUNT, max_ai + 1):
		ai_entries.append({
			"id": "ai_count",
