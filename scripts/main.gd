	return String(actor.get("name", "")) == "蓝锋骑士" and bool(actor.get("blue_lancer_reactive_armor_active", false))


func _maybe_announce_auto_blue_lancer_reactive_armor(slot: int) -> void:
	if slot < 0 or slot >= auto_monsters.size():
		return
