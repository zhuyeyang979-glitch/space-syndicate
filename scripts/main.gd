		business_cycle_count,
		product_name,
		pressure,
		before_price,
		after_price,
	]
	_set_city_public_clue(own_city_index, clue)
	_add_action_callout(
		"ňî┐ňÉŹňĽćńŞÜ",
		"ÚťÇŠ▒éÚÇáňŐ┐",
		"%sÚťÇŠ▒éňÄőňŐŤ+%d´╝îń╗ĚŠá╝šö▒ńżŤÚťÇÚçŹš«Ś´╝ŤňĆ»ŔâŻŠÜ┤Úť▓šöčń║žŠľ╣ňłęšŤŐŃÇé" % [product_name, pressure],
		Color("#f59e0b"),
		_district_center(own_city_index)
