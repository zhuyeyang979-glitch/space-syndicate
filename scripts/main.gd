			{"text": "明军", "state": "%d" % _player_visible_military_count(player_index, viewer_index), "accent": Color("#67e8f9"), "active": _player_visible_military_count(player_index, viewer_index) > 0, "tip": "只显示公开归属的军队线索。"},
