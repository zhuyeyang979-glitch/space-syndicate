	_log("%sňťĘ%sňÉŞňĆľ%s´╝îÚóŁňĄľÚÇáŠłÉ%dšé╣ňî║ňčč/ňčÄňŞéń╝Ąň«│ŃÇé" % [
		String(actor.get("name", "ŠÇ¬ňůŻ")),
		districts[index]["name"],
