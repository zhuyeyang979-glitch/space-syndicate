			"body": "选择玩家后开始操作。",
			"action": {"label": "看星球", "detail": "先选择当前玩家。", "accent": Color("#94a3b8"), "disabled": true, "target": Callable()},
		}
	if _player_is_eliminated(player_index):
		return {
