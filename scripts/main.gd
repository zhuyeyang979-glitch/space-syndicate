func _add_district_products(index: int, products: Array, limit: int) -> Array:
	var added := []
	if index < 0 or index >= districts.size() or limit <= 0:
		return added
	var current: Array = districts[index].get("products", [])
	for product_variant in products:
		if added.size() >= limit:
			break
