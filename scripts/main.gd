		String(actor.get("name", "ŠÇ¬ňůŻ")),
		"ŔÁäŠ║ÉňÉŞňĆľ",
		"%sŔóź%sňÉŞň╝Ľ´╝îÚóŁňĄľÚÇáŠłÉ%dšé╣ń╝Ąň«│ŃÇé" % [match_text, source, drain_damage],
		Color("#f97316"),
		_district_center(index)
