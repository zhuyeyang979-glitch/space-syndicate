func _player_panel_structure_signature() -> String:
	var parts: Array[String] = []
	parts.append("players:%d" % players.size())
	parts.append("selected:%d" % selected_player)
	parts.append("inspected:%d" % inspected_player)
	parts.append("district:%d" % selected_district)
	parts.append("market:%s" % selected_market_skill)
	parts.append("guess:%d:%d" % [selected_card_resolution_id, selected_guess_player])
	parts.append("queue:%d:%d:%s" % [card_resolution_queue.size(), next_card_resolution_queue.size(), str(active_card_resolution.get("resolution_id", ""))])
	parts.append("pending:%s:%s:%s:%d:%d:%d" % [
		str(_has_pending_target_choice()),
		str(_has_pending_player_target_choice()),
		str(_has_pending_blocking_decision()),
		pending_discard_purchase.size(),
		active_monster_wagers.size(),
		pending_contract_offers.size(),
	])
	if selected_district >= 0 and selected_district < districts.size():
		var district: Dictionary = districts[selected_district]
		parts.append("district_state:%s:%s:%s:%s" % [
			str(district.get("name", "")),
			str(district.get("destroyed", false)),
			str(district.get("city_owner", district.get("owner", -1))),
			str((district.get("available_cards", []) as Array).size() if district.get("available_cards", []) is Array else 0),
		])
	if selected_player >= 0 and selected_player < players.size():
		var player: Dictionary = players[selected_player]
		parts.append("opening_guide:%s:%s:%d" % [
			str(opening_guide_dismissed),
			str(_opening_guide_economy_seen(selected_player)),
			_opening_guide_completed_count(selected_player),
		])
		parts.append("player_state:%s:%s:%d:%d:%d:%s" % [
			str(player.get("role_id", player.get("role", ""))),
			str(player.get("eliminated", false)),
			_player_counted_hand_size(player),
			_player_active_city_count(selected_player),
			_first_actionable_hand_slot(selected_player),
			_city_build_error_for(selected_player, selected_district, false) if selected_district >= 0 and selected_district < districts.size() else "no-district",
		])
		var slots: Array = player.get("slots", []) as Array
		for i in range(slots.size()):
			var slot_value = slots[i]
			if slot_value == null:
				parts.append("slot:%d:null" % i)
			elif slot_value is Dictionary:
				var skill := slot_value as Dictionary
				parts.append("slot:%d:%s:%s:%s:%s" % [
					i,
					str(skill.get("name", "")),
					str(skill.get("rank", skill.get("level", ""))),
					str(skill.get("queued_for_resolution", false)),
					str(skill.get("locked_until", "")),
				])
			else:
				parts.append("slot:%d:unknown" % i)
	for i in range(players.size()):
		var public_player: Dictionary = players[i]
		parts.append("seat:%d:%s:%s" % [
			i,
			str(public_player.get("role_id", public_player.get("role", ""))),
			str(public_player.get("eliminated", false)),
		])
	return "|".join(parts)


func _refresh_player_panel_live_values() -> void:
	if player_box == null or players.is_empty() or selected_player < 0 or selected_player >= players.size():
		return
	var entries := _player_resource_cube_entries(selected_player)
	var value_labels := player_box.find_children("PlayerResourceCubeValue", "Label", true, false)
	var label_labels := player_box.find_children("PlayerResourceCubeLabel", "Label", true, false)
	var count := mini(entries.size(), value_labels.size())
	for i in range(count):
		var entry := entries[i] as Dictionary
		var value_label := value_labels[i] as Label
		value_label.text = String(entry.get("value", ""))
		value_label.tooltip_text = String(entry.get("tip", ""))
		if i < label_labels.size():
			var label_label := label_labels[i] as Label
			label_label.text = String(entry.get("label", ""))
			label_label.tooltip_text = String(entry.get("tip", ""))


