		districts[index]["miasma"] = false
		_pulse_district(index, Color("#22c55e"))
		reclaimed += 1
		_log("%sŠîçŠîąŠÇ¬%d┬Ě%sňŤ×ŠöÂ%sšÜäšś┤Š░öŃÇé" % [
			String(skill.get("name", "šś┤Š░öňŤ×ŠöÂ")),
			slot + 1,
			String(actor.get("name", "ŠÇ¬ňůŻ")),
			districts[index]["name"],
		])
	if reclaimed <= 0:
		_log("%sŔîâňŤ┤ňćůŠ▓íŠťëňĆ»ňŤ×ŠöÂšÜäšś┤Š░öŃÇé" % String(skill.get("name", "šś┤Š░öňŤ×ŠöÂ")))
		return false
	actor["hp"] = min(int(actor.get("max_hp", 0)), int(actor.get("hp", 0)) + reclaimed)
	auto_monsters[slot] = actor
	return true


