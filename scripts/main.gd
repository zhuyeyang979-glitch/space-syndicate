		page_count,
		_product_codex_grid_columns(),
		_product_codex_grid_rows(),
		int(report.get("run_product_count", 0)),
		int(report.get("catalog_count", PRODUCT_CATALOG.size())),
		int(report.get("run_ocean_count", 0)),
