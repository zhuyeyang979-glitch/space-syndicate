	if cold_a != cold_b:
		return cold_a > cold_b
	var price_a := int(a.get("price", 0))
	var price_b := int(b.get("price", 0))
	if price_a != price_b:
		return price_a < price_b
	return String(a.get("name", "")) < String(b.get("name", ""))


