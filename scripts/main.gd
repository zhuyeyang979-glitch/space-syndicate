		score += int(city.get("trade_route_damage", 0)) * 92
		score += int(city.get("trade_disrupted_routes", 0)) * 54
		score += int(districts[city_index].get("damage", 0)) * 18
		score += int(districts[city_index].get("panic", 0)) / 4
	return score


