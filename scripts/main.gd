			badges.append("ŠłĹšÜäň▒ĽšĄ║ńŞşňî┐ňÉŹšëî")
		else:
			badges.append("ŠłĹšÜäňÇÖŔíąňî┐ňÉŹšëî")
	for visual_badge in _card_resolution_track_visual_badges(entry, state_text):
