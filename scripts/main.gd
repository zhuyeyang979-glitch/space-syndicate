func _card_resolution_phase_text(entry: Dictionary = {}, seconds_left: float = -1.0) -> String:
	var queued := card_resolution_queue.size()
	var next_queued := next_card_resolution_queue.size()
	if card_resolution_auction_open:
		var auction_intake := "ŠťČŠë╣0.5šžĺš¬ŚňćůňĆ»ňŐáňůą" if card_resolution_simultaneous_timer > 0.0 else "Ŕ┐ŤňůąńŞőńŞÇŠë╣šşëňżů"
		return "ÚśÂŠ«Á´╝Üňî┐ňÉŹšź×ń╗Ě´ŻťňëęńŻÖ%.1fs´ŻťňĆéŠőŹ%d´ŻťŠťÇÚźśňůČň╝ÇŠŐąń╗Ě┬ą%d´ŻťňĆ»ňŐáń╗Ě´╝ÜŠś»´ŻťŠľ░šëî´╝Ü%s´ŻťńŞőŠë╣šşëňżů%d" % [
			max(0.0, card_resolution_auction_timer),
			queued,
			_highest_card_resolution_bid(),
			auction_intake,
			next_queued,
		]
	if not card_resolution_batch_locked and queued > 0:
		return "ÚśÂŠ«Á´╝ÜňÉîŠŚÂňłĄň«Ü´ŻťňëęńŻÖ%.1fs´Żťňżůň«Ü%d´ŻťŠťÇÚźśňůČň╝ÇŠŐąń╗Ě┬ą%d´ŻťňĆ»ňŐáń╗Ě´╝ÜÚóäŔ«ż´ŻťŠľ░šëî´╝Ü0.5šžĺňćůňĆ»ňŐáňůą" % [
			max(0.0, card_resolution_simultaneous_timer),
			queued,
			_highest_card_resolution_bid(),
