	if text.contains("šź×ń╗Ěš║┐š┤ó"):
		return Color("#fde68a")
	if text.contains("ňÉłš║Ž"):
		return Color("#fbbf24")
	if text.contains("ňç║šëîŠŁíń╗Â"):
		return Color("#bbf7d0")
	if text.contains("ŠťÇÚźś"):
		return Color("#fde68a")
	if text.contains("ŠłÉń║Ą") or text.contains("ň░ĆŔ┤╣"):
		return Color("#fde68a")
	if text.contains("ňŻĺň▒×Šť¬ščą"):
		return Color("#94a3b8")
	if text.contains("ňůČň╝ÇňŻĺň▒×"):
