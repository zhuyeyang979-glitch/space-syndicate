	return clampi(index, 0, max(0, _catalog_size() - 1))


func _strip_role_starter_fields(role: Dictionary) -> Dictionary:
	for key in [
		"starter_monster_index",
		"starter_monster_name",
		"starter_monster_card",
		"starter_hp_bonus",
		"starter_duration_bonus",
		"starter_move_multiplier",
		"starter_fixed_skill_bonus",
	]:
		role.erase(key)
	return role


func _role_budget_add_component(report: Dictionary, label: String, points: int, tag: String) -> void:
	if points <= 0:
		return
	report["points"] = int(report.get("points", 0)) + points
	var drivers := report.get("drivers", []) as Array
	drivers.append("%s+%d" % [label, points])
	report["drivers"] = drivers
	var tags := report.get("tags", []) as Array
	if tag != "" and not tags.has(tag):
		tags.append(tag)
	report["tags"] = tags


