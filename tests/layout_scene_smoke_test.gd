	var forbidden_viewmodel_tokens := [
		"Button.new(",
		"Label.new(",
		"PanelContainer.new(",
		"Control.new(",
		"CanvasLayer",
		"Node2D",
		"Sprite2D",
		"add_child(",
		"queue_free(",
		"get_tree(",
		"Callable(",
		"pressed.connect",
	]
	for script_path in VIEWMODEL_SCRIPT_PATHS:
