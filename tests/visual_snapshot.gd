func _expect(condition: bool, message: String) -> void:
	if condition:
		return
	_failures.append(message)
	push_error("Visual layout contract failure: %s" % message)


func _finish() -> void:
	if _failures.is_empty():
		print("Visual layout contract test passed.")
		quit(0)
	else:
		print("Visual layout contract test failed: %s" % " / ".join(_failures))
		quit(1)


func _contains_any(text: String, needles: Array) -> bool:
	for needle_variant in needles:
		if text.contains(String(needle_variant)):
			return true
	return false
