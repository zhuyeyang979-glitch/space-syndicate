accent_color = Color(0.45, 0.82, 0.32, 1)
forecast_duration = 40.0
active_duration = 70.0
fade_duration = 10.0
affected_region_count = 1
product_tags = PackedStringArray("weather_biological", "weather_medicine", "weather_food")
