[gd_resource type="Resource" script_class="CardRuntimeFamilyResource" format=3 uid="uid://du3aw82n1r5c0"]

[sub_resource type="GDScript" id="GDScript_hlnsd"]
script/source = "@tool
extends CardRuntimeDefinitionResource
class_name CardRuntimeRankResource

# One authored rank lives as a subresource inside its family asset.
"

