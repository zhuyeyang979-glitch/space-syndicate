[gd_resource type="Resource" script_class="DevelopmentRouteProfileResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/balance/development_route_profile_resource.gd" id="1"]

[resource]
script = ExtResource("1")
route_id = "contract_route"
display_name = "订单供需"
goal = "用自动结算的条件订单与供货改变商品网络，让真实商路和市场容量产生收益。"
play_pattern = "先识别可达市场、路线方式和距离条件，再提交能由正式经济网络兑现的订单或供货。"
counterplay = "扩充或破坏路线容量、改变供需结构、抢占仓储，或让牌面条件在结算时失效。"
ai_plan_hint = "优先选择公开网络事实可满足、预计净现金高且容量充足的自动订单或供货。"
strategy_labels = Array[String](["条件式供需"])
required_for_ai_baseline = true
sort_order = 1
