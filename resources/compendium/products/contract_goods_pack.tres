[gd_resource type="Resource" script_class="CompendiumContentPackResource" load_steps=9 format=3]

[ext_resource type="Script" path="res://scripts/content/compendium_content_pack_resource.gd" id="1_pack"]
[ext_resource type="Script" path="res://scripts/content/product_codex_entry_resource.gd" id="2_product"]

[sub_resource type="Resource" id="Product_cold_crown_goods"]
script = ExtResource("2_product")
entry_id = "cold_crown_goods"
display_name = "寒冠合约货"
subtitle = "Contract goods practice line"
summary = "A cold-chain product line used by the contract_goods scenario to explain supply, demand, and route pressure."
accent = "#22c55e"
chips = PackedStringArray("Contract", "Cold chain", "contract_goods")
source_note = "Migrated as public codex content from the contract_goods scenario theme. Market math remains in the existing rules layer."
glyph = "CG"
profile = "Contract | cold-chain goods"
terrain = "Terrain: polar port / orbital depot"
price = "$110 | base $90 | contract-sensitive"
demand = "High"
supply = "Medium"
risk = "3 / 5"
volatility = "3"
weather = "Low-orbit weather can delay delivery windows and make route pressure public."
use_case = "Use to teach a simple supply-demand gap before an automatic conditional order checks the public goods network."
kpi_notes = PackedStringArray("Demand spikes when nearby cities lack cold-chain supply.", "Medium supply keeps auctions readable.", "Weather and route changes can move this line.", "Watch visible route pressure before committing.")
strategy_notes = PackedStringArray("Pair with a stable route and clear city demand.", "Compare an automatic order's visible conditions against route risk before committing it.", "Keep all owner-specific reads out of this public entry.")

