[sub_resource type="Resource" id="Monster_spore_fog_sea_king"]
script = ExtResource("2_monster")
entry_id = "spore_fog_sea_king"
display_name = "孢雾海皇"
subtitle = "Active roster monster | fog-dragon silhouette"
summary = "Public ecology reference for the active-roster fog dragon. It pressures harbor routes and creates visible contamination reads."
accent = "#60a5fa"
chips = PackedStringArray("Active roster", "Harbor", "Fog")
source_note = "Migrated from data/art/monster_body_art_manifest.json as a public bestiary Resource. Monster AI and damage rules are unchanged."
hp = 14
armor = 2
move_text = "Move 2 | harbor fog pressure"
style = "瘴气古龙：大翼、云雾、海雾污染"
profile = "A winged fog sea monster that turns harbor routes into public risk zones."
public_tells = PackedStringArray("Large wing silhouette.", "Fog callouts near harbor routes.", "No sensitive player data is stored in this entry.")
action_names = PackedStringArray("Fog Surge", "Harbor Roar")
action_tags = PackedStringArray("route", "event")
action_probabilities = PackedStringArray("I 2/6 | IV 3/6", "I 1/6 | IV 2/6")
action_facts = PackedStringArray("Pressures visible harbor routes.", "Raises public route caution near the coast.")
action_bodies = PackedStringArray("Creates a fog pressure callout on the map.", "Appears as public monster pressure only.")

